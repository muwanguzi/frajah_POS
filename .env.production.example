# Production .env — lives ONLY on the server at /opt/franjah-pos/.env (chmod 600, root-owned).
# Never commit a real copy of this file. docker-compose.prod.yml reads it via env_file.
# DB_HOST/DB_PORT/PORT are intentionally NOT set here — they're fixed by docker-compose.prod.yml
# (the api container always talks to the `postgres` service on the internal Docker network).

NODE_ENV=production

DB_USERNAME=franjah
DB_PASSWORD=replace_with_a_long_random_password
DB_NAME=franjah_pos
# No TypeORM migrations exist yet — keep this true until they're added (see app.module.ts).
DB_SYNCHRONIZE=true

JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_REFRESH_EXPIRES_IN=7d

# Public URL the server is reachable at (used for CORS). Update if you later add a domain.
FRONTEND_URL=http://194.163.179.191

TWO_FACTOR_APP_NAME=FranjahPOS
